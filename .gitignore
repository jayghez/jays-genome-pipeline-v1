.venv/
__pycache__/
.pytest_cache/
*.egg-info/
.coverage
htmlcov/
.DS_Store
.env
.env.*
*.local

# Pipeline outputs can be regenerated and may contain personal genomic data.
outputs/*
!outputs/.gitkeep

# Keep local reference/resource downloads and private inputs out of git by default.
references/
resources/
data/private/

# Do not accidentally commit large or personal VCFs.
*.vcf
*.vcf.gz
*.vcf.gz.tbi
*.bcf
*.bcf.csi
*.tbi
*.csi
!data/sample/.gitkeep
